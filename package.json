{
  "name": "deepiri-client-hub",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:portal": "yarn workspace @deepiri/portal dev",
    "dev:immersive": "yarn workspace @deepiri/immersive dev",
    "dev:server": "yarn workspace @deepiri/server dev",
    "dev:all": "concurrently -n portal,immersive,server -c blue,magenta,green \"yarn dev:portal\" \"yarn dev:immersive\" \"yarn dev:server\""
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "typescript": "^5.3.3"
  },
  "packageManager": "yarn@4.16.0"
}
